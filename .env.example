# ===========================================
# Document AI (Google Cloud) – ruta POST /test/ocr
# ===========================================
# ID del proyecto en Google Cloud Console
GCP_PROJECT_ID=mi-proyecto-gcp
# Región del procesador: us o eu
GCP_LOCATION=us
# ID del procesador OCR (crear en Console: Document AI > Processors > Document OCR)
DOCUMENT_AI_PROCESSOR_ID=abc123def456
# Ruta al JSON de la cuenta de servicio (autenticación). Sin esto, la ruta /test/ocr fallará.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ===========================================
# Gemini 2.5 Flash Lite – rutas /test/clasificacion y /test/extraccion
# ===========================================
# API Key desde https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_gemini

# ===========================================
# App
# ===========================================
PORT=3000
