# 1. System Configuration
GLOBAL_MODE=LOCAL
PORT=3000
NODE_ENV=development

# 2. Infrastructure
DATABASE_URL=postgresql://user:pass@host:port/db
REDIS_HOST=localhost
REDIS_PORT=6379

# 3. Paths Configuration
IN_PATH=./local/in
OCR_PATH=./local/ocr
DONE_PATH=./local/done
# Host paths on your server (Change these to your real server paths)
SERVER_PATH_1=./local/ftp1
SERVER_PATH_2=./local/ftp2
SERVER_PATH_3=./local/ftp3

# Internal container paths for the app (Mapped in docker-compose.yml)
LOCAL_SOURCE_PATHS=/app/source/1,/app/source/2,/app/source/3
LOCAL_CLIENTS_PATH=./local/data
LOCAL_REPORTS_PATH=./local/reports

# 4. Pipeline Settings
CRON_EXTRACTION_SCHEDULE="*/1 * * * *"
CRON_REPORT_SCHEDULE="0 23 * * *"
ALLOWED_EXTENSIONS=.doc,.pdf,.csv,.png,.jpg,.xls

# 5. FTP Settings
FTP_HOST=localhost
FTP_PORT=2121
FTP_USER=user
FTP_PASSWORD=pass
FTP_REMOTE_PATH=/documentos
FTP_CLIENTS_PATH=/clientes
CSV_CLIENTS_FILE=clients.csv

# 6. Gmail Settings
GMAIL_USER=example@gmail.com
GMAIL_APP_PASSWORD=password
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_SEARCH_SUBJECT="DOCUMENTO_PROCESAR"

# 7. AI Services
GCP_PROJECT_ID=project-id
GCP_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=processor-id
GOOGLE_APPLICATION_CREDENTIALS=./secrets/key.json
GEMINI_API_KEY=key
GEMINI_FALLBACK_MODELS="gemini-2.5-flash,gemini-2.5-pro,gemini-2.0-flash"

# 8. Queue Workers & Rate Limits
MODEL_QUEUE_CONCURRENCY=2
MODEL_QUEUE_RPM_LIMIT=15

TENANT_PROFILE=
