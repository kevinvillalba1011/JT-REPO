# 1. System Configuration
GLOBAL_MODE=LOCAL
PORT=3000
NODE_ENV=development

# 2. Infrastructure
DATABASE_URL=postgresql://user:pass@host:port/db
REDIS_HOST=localhost
REDIS_PORT=6379

# 3. Paths Configuration
TMP_IN_PATH=./tmp/in
TMP_OCR_PATH=./tmp/ocr
TMP_DONE_PATH=./tmp/done
TMP_SOURCE_PATH=./tmp/ftp
REPORT_OUTPUT_PATH=./reports
CSV_CLIENTS_PATH=./data/clients.csv

# 4. Pipeline Settings
CRON_EXTRACTION_SCHEDULE="*/1 * * * *"
CRON_REPORT_SCHEDULE="0 23 * * *"
ALLOWED_EXTENSIONS=.doc,.pdf,.csv,.png,.jpg,.xls

# 5. FTP Settings
FTP_HOST=localhost
FTP_PORT=2121
FTP_USER=user
FTP_PASSWORD=pass
FTP_REMOTE_PATH=/
CSV_CLIENTS_FILE=clients.csv

# 6. Gmail Settings
GMAIL_USER=example@gmail.com
GMAIL_APP_PASSWORD=password
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_SEARCH_SUBJECT="DOCUMENTO_PROCESAR"

# 7. AI Services
GCP_PROJECT_ID=project-id
GCP_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=processor-id
GOOGLE_APPLICATION_CREDENTIALS=./secrets/key.json
GEMINI_API_KEY=key
